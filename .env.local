# NEXT AUTH
NEXTAUTH_URL="http://localhost:3000/"
NEXTAUTH_SECRET="uuid_SECRET"

# LOCAL
LOCAL_DATABASE_URL="postgresql://postgres:password@localhost:5432/my_test_db"
LOCAL_URL="http://localhost:3000"

# PRODUCTION
APP_NAME="My App"
ADMIN_API_KEY="uuid_SECRET" # Passed into api/admin calls
PROD_URL="https://mydomain.com"

# AWS
AWS_REGION="us-east-1"
SES_ACCESS_KEY="YOUR_AWS_SES_ACCESS_KEY"
SES_SECRET_KEY="YOUR_AWS_SES_SECRET_KEY"
SES_FROM_EMAIL_ADDRESS="Example Name <test@gmail.com>"

# STRIPE
STRIPE_PUBLISHABLE_KEY="YOUR_STRIPE_PUBLIC_KEY"
STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_KEY="YOUR_STRIPE_WEBHOOK_KEY"
STRIPE_LIVE_PRODUCT_PRICE_ID="STRIPE_LIVE_PRODUCT_PRICE_ID"
STRIPE_TEST_PRODUCT_PRICE_ID="STRIPE_TEST_PRODUCT_PRICE_ID"

# APP VARIABLES
SALT_ROUNDS = "10"

# GOOGLE SIGN IN
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
